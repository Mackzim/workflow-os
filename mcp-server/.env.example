# Workflow OS MCP server config. Copy to `.env` and fill in.
# These values stay LOCAL on your machine. NEVER commit this file or share the service_role key.

# Supabase project URL (same as the app)
SUPABASE_URL=https://nddhuiglivlejtezneqb.supabase.co

# service_role key — Supabase → Project Settings → API → "service_role" (SECRET!).
# It runs only locally in this MCP server (never in the browser). Full DB access, so keep it private.
SUPABASE_SERVICE_ROLE_KEY=

# Your account email (the server resolves your user id from it and scopes all task ops to you).
WORKFLOW_USER_EMAIL=felix@pichler.de
