{
  "name": "workflow-os-mcp-server",
  "version": "0.1.0",
  "description": "MCP server that lets Claude control Workflow OS tasks (writes to Supabase, syncs live to the dashboard).",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "workflow-os-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "check": "node dist/index.js --check"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.45.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
