{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Workflow OS",
  "version": "0.1.0",
  "identifier": "de.pichler.workflowos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Workflow OS",
        "width": 1280,
        "height": 832,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#0a0b0e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Felix Pichler",
    "category": "Productivity",
    "shortDescription": "Personal workflow operating system",
    "longDescription": "Workflow OS – a local-first personal command center for tasks, dashboards and Claude-driven automations.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
